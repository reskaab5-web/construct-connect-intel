# ──────────────────────────────────────────
# District Intelligence Platform — Env Vars
# Copy to .env and fill in your values
# ──────────────────────────────────────────

# Supabase (from your project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...  # service_role key (NOT anon key)
SUPABASE_ANON_KEY=eyJhbGci...    # anon key for dashboard read access

# Google / YouTube Data API v3
# Create at: https://console.developers.google.com/
# Enable: YouTube Data API v3
YOUTUBE_API_KEY=AIzaSy...

# Anthropic (Claude)
# Get at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: email digest delivery
SENDGRID_API_KEY=SG....
DIGEST_EMAIL=ron.sams@locallaunchmedia.com
DIGEST_FROM_EMAIL=noreply@locallaunchmedia.com
