# Copy this to .env and fill in your values
# Then run: source .env && python cc_intel_refresh.py

# === Required ===

# Anthropic (for Claude district analysis)
ANTHROPIC_API_KEY=sk-ant-...

# === ConstructConnect — pick ONE method ===

# Option A: CC API key (if you have direct API access)
CC_API_KEY=

# Option B: Path to a CC CSV export file
# Export from CC → filter K-12 California → download CSV → set path here
CC_EXPORT_PATH=/path/to/constructconnect_export.csv

# === SchoolBondFinder ===
SBF_EMAIL=your@email.com
SBF_PASSWORD=yourpassword

# === Deployment — pick ONE method ===

# Option A: Vercel deploy hook (fastest)
# In Vercel dashboard → project → Settings → Git → Deploy Hooks → create one
VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/...

# Option B: GitHub push (triggers Vercel auto-deploy)
GITHUB_TOKEN=ghp_...
GITHUB_REPO=yourusername/construct-connect-intel

# === Optional ===

# Supabase (for saving signals)
SUPABASE_URL=https://jeeogenehsdvaxxqqjtv.supabase.co
SUPABASE_KEY=eyJ...
